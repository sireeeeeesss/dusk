# Workspace "Run" + Deploy: https://docs.replit.com/core-concepts/workspace/app-setup/configuration
modules = ["nodejs-20"]

build = "npm install && npm run build"
run = "npm run start -w server"

[nix]
channel = "stable-23_11"

[deployment]
build = ["sh", "-c", "npm install && npm run build"]
run = ["sh", "-c", "npm run start -w server"]
deploymentTarget = "cloudrun"
