generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  username         String   @unique
  passwordHash     String
  /** Existing accounts default verified; new signups set false until code confirmed */
  emailVerified    Boolean  @default(true)
  emailVerificationCodeHash    String?
  emailVerificationCodeExpiresAt DateTime?
  emailVerificationSentAt      DateTime?
  passwordResetCodeHash          String?
  passwordResetCodeExpiresAt     DateTime?
  passwordResetSentAt            DateTime?
  displayName      String
  avatarHue        Int      @default(220)
  accentHue        Int      @default(32)
  bio              String   @default("")
  customStatus     String   @default("")
  avatarImageMime  String?
  bannerImageMime  String?
  createdAt        DateTime @default(now())
  /** "everyone" | "friends_only" | "no_one" — DM policy for non-friend flows */
  dmPrivacy        String   @default("everyone")

  memberships              Membership[]
  messages                 Message[]                 @relation("MessageAuthor")
  ownedServers             Server[]                  @relation("ServerOwner")
  conversationParticipants ConversationParticipant[]
  dmMessages               DmMessage[]               @relation("DmAuthor")
  messageReactions         MessageReaction[]
  friendRequestsSent       FriendRequest[]           @relation("FriendRequestFrom")
  friendRequestsReceived   FriendRequest[]           @relation("FriendRequestTo")
  friendshipsAsA         Friendship[]              @relation("FriendshipUserA")
  friendshipsAsB         Friendship[]              @relation("FriendshipUserB")
  dmRequestsSent           DmRequest[]               @relation("DmRequestFrom")
  dmRequestsReceived       DmRequest[]               @relation("DmRequestTo")
  presence                 UserPresence?
}

model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())

  userA User @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model FriendRequest {
  id          String    @id @default(cuid())
  fromUserId  String
  toUserId    String
  /** pending | accepted | declined | cancelled */
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  fromUser User @relation("FriendRequestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("FriendRequestTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
}

model DmRequest {
  id             String    @id @default(cuid())
  fromUserId     String
  toUserId       String
  /** pending | accepted | declined | cancelled */
  status         String    @default("pending")
  conversationId String?
  createdAt      DateTime  @default(now())
  respondedAt    DateTime?

  fromUser     User          @relation("DmRequestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser       User          @relation("DmRequestTo", fields: [toUserId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@unique([fromUserId, toUserId])
}

model UserPresence {
  userId    String   @id
  isOnline  Boolean  @default(false)
  lastSeenAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Server {
  id         String   @id @default(cuid())
  name       String
  iconMime   String?
  inviteCode String   @unique
  ownerId    String
  owner      User     @relation("ServerOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  channels    Channel[]
  memberships Membership[]
}

model Membership {
  id       String @id @default(cuid())
  userId   String
  serverId String
  role     String @default("member")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([userId, serverId])
}

model Channel {
  id        String   @id @default(cuid())
  serverId  String
  name      String
  /** "text" | "voice" — voice channels use live WebRTC, not message history */
  kind      String   @default("text")
  position  Int      @default(0)
  createdAt DateTime @default(now())

  server   Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id         String   @id @default(cuid())
  channelId  String
  authorId   String
  content    String
  hasVoice   Boolean  @default(false)
  voiceMime  String?
  hasImage   Boolean  @default(false)
  imageMime  String?
  hasVideo   Boolean  @default(false)
  videoMime  String?
  hasAudio   Boolean  @default(false)
  audioMime  String?
  mentionIds String   @default("[]")
  editedAt   DateTime?
  createdAt  DateTime @default(now())

  channel   Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author    User              @relation("MessageAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  reactions MessageReaction[]
}

model MessageReaction {
  id        String @id @default(cuid())
  messageId String
  userId    String
  emoji     String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model Conversation {
  id        String   @id @default(cuid())
  isGroup   Boolean  @default(false)
  createdAt DateTime @default(now())

  participants ConversationParticipant[]
  messages     DmMessage[]
  dmRequests   DmRequest[]
}

model ConversationParticipant {
  id             String @id @default(cuid())
  conversationId String
  userId         String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model DmMessage {
  id             String   @id @default(cuid())
  conversationId String
  authorId       String
  content          String
  hasVoice         Boolean  @default(false)
  voiceMime        String?
  hasImage         Boolean  @default(false)
  imageMime        String?
  hasVideo         Boolean  @default(false)
  videoMime        String?
  hasAudio         Boolean  @default(false)
  audioMime        String?
  mentionIds       String   @default("[]")
  editedAt         DateTime?
  createdAt        DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author         User         @relation("DmAuthor", fields: [authorId], references: [id], onDelete: Cascade)
}
