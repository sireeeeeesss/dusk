# --- Database (required) ---
# Local: from repo root run `npm run db:up`, then:
DATABASE_URL=postgresql://dusk:dusk@localhost:5432/dusk
# Production (Neon / Supabase / Render Postgres): paste their URL, often ends with ?sslmode=require

# --- API ---
# Local default is 3333 if unset. On Replit, PORT is set (often 3000) — don’t run two servers on the same port.
PORT=3333
JWT_SECRET=change-me-in-prod
NODE_ENV=development

# Web app origin (CORS + default links in emails)
CLIENT_URL=http://127.0.0.1:5173
# If the app URL users open in the browser differs from CLIENT_URL, set this for email links only:
# PUBLIC_APP_URL=https://your-app.example.com

# --- Email (pick Resend OR SMTP) ---
# Recommended live: https://resend.com — verify a domain, then use noreply@yourdomain
MAIL_APP_NAME=Dusk
# Full From header or bare address (we prefix with MAIL_APP_NAME if needed):
MAIL_FROM=Dusk <onboarding@resend.dev>
# RESEND_FROM=...          # legacy alias for MAIL_FROM
MAIL_REPLY_TO=

# Replit Secrets: name must be exactly RESEND_API_KEY (not "Resend" with spaces).
RESEND_API_KEY=
# With only RESEND_API_KEY set, we default From to onboarding@resend.dev. For your domain:
# MAIL_FROM=Dusk <noreply@yourdomain.com>

# SMTP (Gmail, Mailgun, etc.) — Render free tier blocks outbound 25/465/587; use Resend or a host that allows SMTP
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@yourdomain.com

# --- Profile images (easiest on Render): Cloudinary — one env var from the dashboard ---
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# When set, avatar + banner uploads use Cloudinary (HTTPS URLs); no R2/S3 needed for pfp/banner.

# --- Media (optional; S3-compatible: AWS S3, Cloudflare R2, MinIO) ---
# When all bucket + credentials are set, message attachments + server icons use object storage instead of local disk.
# Avatars/banners use S3 only if CLOUDINARY_URL is unset.
# S3_BUCKET=dusk-media
# S3_REGION=us-east-1
# For Cloudflare R2 use region "auto" and your R2 endpoint:
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY also work)
